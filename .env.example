# ── Required ──────────────────────────────────────────────────────────────────
# Groq API key (required)
GROQ_API_KEY=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

# ── Strongly recommended ──────────────────────────────────────────────────────
# HMAC secret for IP address hashing.
# Without this, rate-limit counters reset on every restart (brief abuse window).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HMAC_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────
# Public URL for strict CORS check (e.g. https://techvibe.az)
APP_URL=

# Set to "true" ONLY behind a trusted reverse proxy (Nginx, Cloudflare, etc.)
# Prevents X-Forwarded-For spoofing on bare deployments.
TRUST_PROXY=false

# Server port (default: 3000)
PORT=3000

# Set to "production" for production deployments
NODE_ENV=development
